# Laravel + `ship` deploy adapter — append these to your bot/.env (adjust the paths).
# They wire deploy-run.sh's pluggable GATE_CMD / DEPLOY_CMD to the scripts in this
# folder. Absolute paths; forward slashes are fine on Windows / Git Bash.

# Enforce the "no DB migrations" house rule across plan/review/code:
RULES_FILE=/path/to/agent-plan-review-loop/examples/rules/laravel-no-ddl.md

# Deploy gate: php -l on changed files + app boot + (opt-in) phpunit.
GATE_CMD=bash /path/to/agent-plan-review-loop/examples/laravel/laravel-gate.sh

# Deploy step: run your ship script as `ship <project> prod`.
DEPLOY_CMD=bash /path/to/agent-plan-review-loop/examples/laravel/laravel-deploy.sh
SHIP_SCRIPT=/path/to/ship.sh

# --- optional knobs consumed by the Laravel gate / deploy ---
# Use a specific PHP binary for this checkout:
# PHP=/path/to/php
# Syntax-only gate (project has no compatible local PHP):
# LINT_ONLY=1
# Run phpunit (ONLY for projects with a test DB + dev deps):
# RUN_TESTS=1
# JSON {project-key: ship-name} — when the deploy target differs from the repo dir name:
SHIP_PROJECTS={}
# comma-separated project keys with NO deploy button (e.g. containerised apps):
NO_DEPLOY=
