# Copy to .env and fill in. .env is gitignored — never commit your token.

# ─── Required ────────────────────────────────────────────────────────────────
# Create a NEW bot via @BotFather and paste its token here.
TELEGRAM_BOT_TOKEN=<your-bot-token>

# Your Telegram chat id. Send /whoami to the bot to learn it. Comma-separate for several.
TELEGRAM_ALLOWED_CHAT_ID=

# Default target repo the agents work against (forward slashes are fine on Windows).
PLAN_REPO=/path/to/your-repo

# ─── Optional: named projects for "/plan <name> TASK-1 ..." (JSON: key -> repo) ──
PLAN_PROJECTS={"app":"/path/to/your-repo","api":"/path/to/another-repo"}

# ─── Models & iterations ─────────────────────────────────────────────────────
# AUTO-picked per task by a complexity tier (Haiku classifier):
#   T0/T1 (trivial/small) -> sonnet author + opus reviewer + sonnet coder, 3 rounds
#   T2 (complex)          -> opus author + sonnet reviewer + opus coder,   6 rounds
# Author and reviewer are always DIFFERENT models (decorrelation). Uncomment to PIN:
# AUTHOR_MODEL=opus
# REVIEWER_MODEL=sonnet
# CODER_MODEL=opus
# MAX_ITERS=6
# SCORER_MODEL=haiku
# LOG_COST=1
PERM_MODE=acceptEdits

# Auto-chain plan -> code (1 = on; 0 = tap a button after each plan). Deploy is always a manual tap.
AUTO_CODE=1

# ─── Optional: project rules (hard constraints) injected into every agent prompt ──
# Point at a markdown file, or drop ".agent-workflow-rules.md" in a repo. See examples/rules/.
# RULES_FILE=/path/to/agent-plan-review-loop/examples/rules/no-new-dependencies.md

# ─── Optional: deploy (pluggable) ────────────────────────────────────────────
# deploy-run.sh runs:  merge -> GATE_CMD -> push -> DEPLOY_CMD.
# DEPLOY_CMD is required for the deploy button to do anything; GATE_CMD is optional.
# Worked deploy adapters live in examples/.
# GATE_CMD=bash /path/to/your-gate.sh
# DEPLOY_CMD=bash /path/to/your-deploy.sh
# SHIP_PROJECTS={}                # optional JSON {project-key: deploy-target-name}
# NO_DEPLOY=                      # comma-separated project keys with NO deploy button

# ─── Optional: Cursor as the REVIEWER (cross-family decorrelation / separate budget) ──
# Author + coder stay on Claude; only the review is rerouted. Requires cursor-agent installed.
# REVIEWER_PROVIDER=cursor
# REVIEWER_MODEL_CURSOR_T1=composer-2.5-fast
# REVIEWER_MODEL_CURSOR_T2=gpt-5.3-codex

# ─── Optional: misc ──────────────────────────────────────────────────────────
# MAX_PARALLEL=5                  # max concurrent tickets
# AUTOSTART=1                     # 0 to disable login autostart (read by start-bot scripts)
# PLAN_BASH=/c/Program Files/Git/bin/bash.exe   # override bash discovery
# PLAN_PYTHON=/path/to/python.exe               # override python for the Windows launcher
